.idea/
*.swp
*.swo
*~
.DS_Store

# VSCode local overrides (the shared settings.json/extensions.json IS committed)
.vscode/*.local
.vscode/launch.json
.vscode/tasks.json

# Local environment
.env
.env.local
*.local.yaml
*.local.yml

# Claude Code per-checkout state, including worktrees
.claude/
